/* pages/carinfo2/carinfo2.wxss */
.carinfo2-content{
  padding:3em 0 0 ;
}
.carinfo2-content .ul .li image{
  width: 1.5em;
  height: 1.5em;
  float: right;
}
.car-pay{
  position: fixed;
  bottom: 0;
  width: 100%;
  background: linear-gradient(to right, #eec667 , #f6a74d);
  left: 0;
  text-align: center;
  color: #fff;
  padding: 0.85em 0;
  font-size: 1em;
}


.modal-mask {
  width: 100%;
  height: 100%;
  position: fixed;
  top: 0;
  left: 0;
  background: #000;
  opacity: 0.5;
  overflow: hidden;
  z-index: 9000;
  color: #fff;
}
.yuyue{
  padding:1em;
}
.yuyue .ul .li{
  padding: 1em 0;
  border-bottom: 1px solid #eee;
}
.yuyue .ul .li text,.yuyue .ul .li input{
  display: inline-block;
  vertical-align: middle;
}
.yuyue .ul .tips{
  font-size: 0.85em;
  color: #999;
}
.btn{
  background: #12315d;
  text-align: center;
  color: #fff;
  padding: 0.75em 0;
  margin: 3em 0;
}
.modal-dialog {
  width: 90%;
  overflow: hidden;
  position: fixed;
  top: 50%;
  left: 50%;
  z-index: 9999;
  background: #f9f9f9;
  transform: translate(-50%,-50%);
  border-radius: 36rpx;
}
.modal-title {
  padding-top: 50rpx;
  font-size: 36rpx;
  color: #030303;
  text-align: center;
}
